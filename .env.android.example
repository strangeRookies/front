# USB development uses adb reverse, so 127.0.0.1 on the phone is forwarded to
# the development PC. Re-run the adb reverse commands after reconnecting USB.
VITE_BACKEND_BASE_URL=http://127.0.0.1:8080
VITE_BACKEND_WS_URL=ws://127.0.0.1:8080/ws

VITE_STREAM_MODE=mjpeg
VITE_MJPEG_BASE_URL=http://127.0.0.1:8010
VITE_MJPEG_PORT_END=8020
VITE_STREAM_FALLBACK_ENABLED=false
