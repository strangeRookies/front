VITE_STREAM_BASE_URL=http://localhost:8888
VITE_BACKEND_BASE_URL=http://localhost:8080

VITE_S3_BUCKET_URL=http://safety-web-dashboard-bucket.s3-website.ap-northeast-2.amazonaws.com

# WebRTC / HLS / MJPEG streaming configurations
VITE_WEBRTC_BASE_URL=http://localhost:8889
VITE_HLS_BASE_URL=http://localhost:8888
VITE_MJPEG_BASE_URL=http://localhost:8010
VITE_OVERLAY_BASE_URL=http://localhost:8010
VITE_MJPEG_PORT_END=8020
VITE_MJPEG_BASE_PATH=/mjpeg
VITE_MJPEG_PROXY_MODE=false

# Stream mode: mjpeg | webrtc | raw | overlay
VITE_STREAM_MODE=mjpeg
VITE_STREAM_FALLBACK_ENABLED=true
VITE_BACKEND_WS_URL=ws://localhost:8080/ws

# Frontend overlay rendering flags. Keep these off in mjpeg mode when the AI worker bakes overlays into JPEG frames.
VITE_FRONT_OVERLAY_SYNC_DEBUG=false
VITE_FRONT_STOMP_OVERLAY_RENDER=false
VITE_FRONT_OVERLAY_CLEAR_GRACE_MS=300
VITE_FRONT_OVERLAY_DELAY_MS=6000
VITE_FRONT_OVERLAY_MAX_RENDER_AGE_MS=10000
VITE_FRONT_OVERLAY_MATCH_THRESHOLD_MS=2000
