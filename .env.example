VITE_STREAM_MODE=webrtc
# WebRTC / HLS Base URLs
# Option A: Direct GPU PC IP Connection (e.g. http://192.168.0.66:8888)
# Option B: SSH Local Port Forwarding (e.g. ssh -L 8888:127.0.0.1:8888 welabs@192.168.0.66)
VITE_HLS_BASE_URL=http://localhost:8888
# Option A: Direct GPU PC IP Connection (e.g. http://192.168.0.66:8889)
# Option B: SSH Local Port Forwarding (e.g. ssh -L 8889:127.0.0.1:8889 welabs@192.168.0.66)
VITE_WEBRTC_BASE_URL=http://localhost:8889
VITE_STREAM_FALLBACK_ENABLED=true
VITE_OVERLAY_BASE_URL=http://localhost:8010
VITE_BACKEND_BASE_URL=http://localhost:18080
VITE_BACKEND_WS_URL=ws://localhost:18080/ws
VITE_S3_BUCKET_URL=http://safety-web-dashboard-bucket.s3-website.ap-northeast-2.amazonaws.com
VITE_FRONT_OVERLAY_SYNC_DEBUG=false
VITE_FRONT_OVERLAY_DELAY_MS=300
VITE_FRONT_OVERLAY_MAX_BUFFER_AGE_MS=5000
VITE_FRONT_OVERLAY_MAX_BUFFER_SIZE=300
VITE_FRONT_OVERLAY_MATCH_THRESHOLD_MS=200
